# EmblemAI Agent Wallet Configuration Template
# Copy this file to ~/.emblemai/.env and encrypt with dotenvx
# Or use as a reference for environment variables

# Authentication
# ==============
# Your EmblemVault password (minimum 16 characters)
# This password creates/accesses your deterministic wallet
# NEVER share this password - it controls your funds
EMBLEM_PASSWORD=""

# Optional: Custom API endpoints
# ==============================
# HUSTLE_API_URL="https://api.agenthustle.ai/v1"  # Legacy env var name for the EmblemAI API endpoint
# AUTH_API_URL="https://auth.emblemvault.ai/v1"
# API_BASE_URL="https://api.emblemvault.ai/v1"

# Optional: CLI behavior
# ======================
# Enable debug mode by default
# DEBUG_MODE="true"

# Disable streaming responses
# STREAMING="false"

# Custom log file location
# LOG_FILE="/path/to/custom.log"

# Optional: Payment settings
# ==========================
# PAYMENT_TOKEN="SOL"  # SOL, ETH, HUSTLE, USDC, etc.
# PAYMENT_MODE="debt_accumulation"  # pay_per_request or debt_accumulation

# Optional: Model selection
# =========================
# MODEL_ID="claude-sonnet-4-6"  # or other supported model

# Environment Notes:
# =================
# 1. This file should be encrypted with dotenvx for production use:
#    dotenvx encrypt -o ~/.emblemai/.env
#
# 2. The encryption key will be saved to ~/.emblemai/.env.keys
#
# 3. Both files will have permissions set to 600 (owner read/write only)
#
# 4. For development/testing, you can use this file unencrypted
#
# 5. CLI arguments override environment variables

# Security Warning:
# ================
# - Never commit this file to version control
# - Never share your password
# - Use different passwords for different wallets/purposes
# - Store backup of password in secure password manager
# - This password cannot be recovered if lost
